                </mxCell>
                <mxCell id="221" value="&lt;b&gt;2FN:&lt;/b&gt;&lt;div&gt;&lt;b&gt;1.-Debe encontrarse en FN1&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;2.-No deben existir Dependencias Funcionales Transitivas&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;div&gt;La PK de la entidad debe ser compuesta, se evalúan si los atriobutos dependan de toda las claves de la PK compuesta o lo que es lo mismo no debe depender parcialmente (no de todas) de la PK compuesta&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
                    <mxGeometry x="360" y="600" width="270" height="150" as="geometry"/>
                </mxCell>
