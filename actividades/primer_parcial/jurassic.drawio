                <mxCell id="217" value="Se genera esta nueva entidad y se le aplica la&lt;div&gt;&lt;b&gt;FN1. Esta hereda las PK del padre como FK&lt;/b&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
