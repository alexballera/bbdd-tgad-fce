                <mxCell id="218" value="Se genera esta nueva entidad y se le aplica la&lt;div&gt;PK de su entidad &quot;padre&quot; o generadora&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
